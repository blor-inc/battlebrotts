; SIGNAL CONNECTIONS
; ════════════════════════════════════════════════════════════
[connection signal="pressed" from="CanvasLayer/MainMenu/NewGameButton" to="CanvasLayer/MainMenu" method="_on_new_game_pressed"]
[connection signal="pressed" from="CanvasLayer/MainMenu/ContinueButton" to="CanvasLayer/MainMenu" method="_on_continue_pressed"]
[connection signal="item_selected" from="CanvasLayer/ShopScreen/CategoryList" to="CanvasLayer/ShopScreen" method="_on_category_selected"]
[connection signal="item_selected" from="CanvasLayer/ShopScreen/ShopItemList" to="CanvasLayer/ShopScreen" method="_on_item_selected"]
[connection signal="pressed" from="CanvasLayer/ShopScreen/BuyButton" to="CanvasLayer/ShopScreen" method="_on_buy_pressed"]
[connection signal="pressed" from="CanvasLayer/ShopScreen/ShopContinueButton" to="CanvasLayer/ShopScreen" method="_on_continue_pressed"]
[connection signal="item_selected" from="CanvasLayer/LoadoutScreen/ChassisList" to="CanvasLayer/LoadoutScreen" method="_on_chassis_selected"]
[connection signal="multi_selected" from="CanvasLayer/LoadoutScreen/WeaponList" to="CanvasLayer/LoadoutScreen" method="_on_weapon_selected"]
[connection signal="item_selected" from="CanvasLayer/LoadoutScreen/ArmorList" to="CanvasLayer/LoadoutScreen" method="_on_armor_selected"]
[connection signal="multi_selected" from="CanvasLayer/LoadoutScreen/ModuleList" to="CanvasLayer/LoadoutScreen" method="_on_module_selected"]
[connection signal="pressed" from="CanvasLayer/LoadoutScreen/FightButton" to="CanvasLayer/LoadoutScreen" method="_on_fight_pressed"]
[connection signal="item_selected" from="CanvasLayer/OpponentSelect/OpponentList" to="CanvasLayer/OpponentSelect" method="_on_opponent_selected"]
[connection signal="pressed" from="CanvasLayer/OpponentSelect/OpponentFightButton" to="CanvasLayer/OpponentSelect" method="_on_fight_pressed"]
[connection signal="pressed" from="CanvasLayer/OpponentSelect/OpponentBackButton" to="CanvasLayer/OpponentSelect" method="_on_back_pressed"]
[connection signal="pressed" from="CanvasLayer/MatchScreen/HUD/SpeedButton" to="CanvasLayer/MatchScreen/HUD" method="_on_speed_pressed"]
[connection signal="pressed" from="CanvasLayer/ResultScreen/RematchButton" to="CanvasLayer/ResultScreen" method="_on_rematch_pressed"]
[connection signal="pressed" from="CanvasLayer/ResultScreen/LoadoutButton" to="CanvasLayer/ResultScreen" method="_on_loadout_pressed"]
